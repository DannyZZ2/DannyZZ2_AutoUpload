{
  "name": "multi-platform-publisher",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,green \"tsx watch src/server/index.ts\" \"vite --host 127.0.0.1\"",
    "dev:open": "concurrently -n api,web -c cyan,green \"tsx watch src/server/index.ts\" \"vite --host 127.0.0.1 --open /\"",
    "dev:api": "tsx watch src/server/index.ts",
    "dev:web": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "tsx src/server/index.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9.0.3",
    "@fastify/static": "^8.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "fastify": "^5.2.1",
    "lucide-react": "^0.468.0",
    "playwright": "^1.49.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.0.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
